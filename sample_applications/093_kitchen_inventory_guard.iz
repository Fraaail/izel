draw std/io
draw std::iter::*

shape App093Counter {
    ~n: i32
    limit: i32
}

impl Iterator for App093Counter {
    type Item = i32

    forge next(&~self) -> ?i32 {
        given self.n < self.limit {
            let out = self.n
            self.n = self.n + 1
            give Some(out)
        }
        None
    }
}

forge main() -> int {
    println("093: kitchen inventory guard")
    let ~it = App093Counter { n: 0, limit: 8 }
    let a = it.next()
    let b = it.next()
    let c = it.next()
    println("iterator stepped")
    give 0
}
