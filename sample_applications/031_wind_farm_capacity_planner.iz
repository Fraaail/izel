draw std/io

@requires(lo <= hi)
@ensures(result >= lo and result <= hi)
forge app031_wind_farm_capacity_planner_clamp(v: int, lo: int, hi: int) -> int {
    given v < lo { give lo }
    given v > hi { give hi }
    give v
}

forge main() -> int {
    println("031: wind farm capacity planner")
    let bounded = app031_wind_farm_capacity_planner_clamp(163, 19, 96)
    println("bounded")
    println_int(bounded)
    give 0
}
