draw std/io
draw std/mem

forge app088_hydration_goal_monitor_simulate_buffer(bytes: int) -> int {
    let p = alloc(bytes)
    free(p)
    give bytes - 8
}

forge main() -> int {
    println("088: hydration goal monitor")
    let blocks = app088_hydration_goal_monitor_simulate_buffer(334)
    println("buffer blocks")
    println_int(blocks)
    give 0
}
