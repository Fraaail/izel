draw std/io

@requires(lo <= hi)
@ensures(result >= lo and result <= hi)
forge app006_freelance_rate_planner_clamp(v: int, lo: int, hi: int) -> int {
    given v < lo { give lo }
    given v > hi { give hi }
    give v
}

forge main() -> int {
    println("006: freelance rate planner")
    let bounded = app006_freelance_rate_planner_clamp(88, 21, 96)
    println("bounded")
    println_int(bounded)
    give 0
}
