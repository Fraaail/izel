draw std/io

scroll App065Status {
    Stable,
    Watch,
    Critical,
}

forge app065_compliance_risk_report_state(v: int) -> int {
    given v <= 0 { give 0 }
    given v == 1 { give 1 }
    give 2
}

forge main() -> int {
    println("065: compliance risk report")
    let state = app065_compliance_risk_report_state(5)
    println_int(state)
    give 0
}
