draw std/io

@requires(lo <= hi)
@ensures(result >= lo and result <= hi)
forge app081_learning_progress_tracker_clamp(v: int, lo: int, hi: int) -> int {
    given v < lo { give lo }
    given v > hi { give hi }
    give v
}

forge main() -> int {
    println("081: learning progress tracker")
    let bounded = app081_learning_progress_tracker_clamp(313, 15, 96)
    println("bounded")
    println_int(bounded)
    give 0
}
