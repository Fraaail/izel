draw std/io

ward app049_search_relevance_tuner_core {
    open shape Window {
        open low: i32,
        open high: i32,
    }

    pure forge span(_w: Window) -> i32 {
        7
    }
}

forge main() -> int {
    println("049: search relevance tuner")
    let w = app049_search_relevance_tuner_core::Window { low: 19, high: 217 }
    let width = app049_search_relevance_tuner_core::span(w)
    println_int(width)
    give 0
}
