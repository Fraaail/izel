draw std/io

scroll App090Status {
    Stable,
    Watch,
    Critical,
}

forge app090_personal_finance_coach_state(v: int) -> int {
    given v <= 0 { give 0 }
    given v == 1 { give 1 }
    give 2
}

forge main() -> int {
    println("090: personal finance coach")
    let state = app090_personal_finance_coach_state(0)
    println_int(state)
    give 0
}
