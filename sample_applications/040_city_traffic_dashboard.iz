draw std/io

scroll App040Status {
    Stable,
    Watch,
    Critical,
}

forge app040_city_traffic_dashboard_state(v: int) -> int {
    given v <= 0 { give 0 }
    given v == 1 { give 1 }
    give 2
}

forge main() -> int {
    println("040: city traffic dashboard")
    let state = app040_city_traffic_dashboard_state(0)
    println_int(state)
    give 0
}
