// examples/async_test.iz

// Minimal async/tide syntax coverage fixture.

shape Result<T, E> {
    is_ok: bool,
    value: T,
}

// A generic synchronous fetch function
forge fetch_data_sync() -> i32 {
    42
}

// A generic async fetch function
flow forge fetch_data_async() -> i32 {
    100
}

flow forge main() {
    // 1. Calling a sync function
    let sync_val = fetch_data_sync()

    // 2. Calling an async function requires tide
    let async_val = tide fetch_data_async()

    // 3. Let's make sure tide is parsed as a Unary Expr and works.
    let double_async = tide fetch_data_async() + tide fetch_data_async()

    // 4. Keep this fixture focused on `flow` + `tide` behavior.
}

// 5. This should trigger an error because `tide` is outside a `flow` forge:
forge bad_tide() {
    let v = tide fetch_data_async()
}
