draw std::io;

ward math {
    open shape Point {
        open x: f64,
        open y: f64,
    }
}

scroll Status {
    Ok,
    Error(str),
    Loading { progress: f32 },
}

weave Printable {
    forge format(&self) -> str;
}

weave Printable for Status {
    forge format(&self) -> str {
        "status"
    }
}

forge main() {
    let x = 1 + 2;
}
